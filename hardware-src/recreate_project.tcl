# Proc to create BD fir_compiler_sim
proc cr_bd_fir_compiler_sim { parentCell } {

  # CHANGE DESIGN NAME HERE
  set design_name fir_compiler_sim

  common::send_msg_id "BD_TCL-003" "INFO" "Currently there is no design <$design_name> in project, so creating one..."

  create_bd_design $design_name

  set bCheckIPsPassed 1
  ##################################################################
  # CHECK IPs
  ##################################################################
  set bCheckIPs 1
  if { $bCheckIPs == 1 } {
     set list_check_ips "\ 
  xilinx.com:ip:c_addsub:12.0\
  xilinx.com:ip:dds_compiler:6.0\
  xilinx.com:ip:fir_compiler:7.2\
  xilinx.com:ip:sim_clk_gen:1.0\
  xilinx.com:ip:xlconstant:1.1\
  "

   set list_ips_missing ""
   common::send_msg_id "BD_TCL-006" "INFO" "Checking if the following IPs exist in the project's IP catalog: $list_check_ips ."

   foreach ip_vlnv $list_check_ips {
      set ip_obj [get_ipdefs -all $ip_vlnv]
      if { $ip_obj eq "" } {
         lappend list_ips_missing $ip_vlnv
      }
   }

   if { $list_ips_missing ne "" } {
      catch {common::send_msg_id "BD_TCL-115" "ERROR" "The following IPs are not found in the IP Catalog:\n  $list_ips_missing\n\nResolution: Please add the repository containing the IP(s) to the project." }
      set bCheckIPsPassed 0
   }

  }

  if { $bCheckIPsPassed != 1 } {
    common::send_msg_id "BD_TCL-1003" "WARNING" "Will not continue with creation of design due to the error(s) above."
    return 3
  }

  variable script_folder

  if { $parentCell eq "" } {
     set parentCell [get_bd_cells /]
  }

  # Get object for parentCell
  set parentObj [get_bd_cells $parentCell]
  if { $parentObj == "" } {
     catch {common::send_msg_id "BD_TCL-100" "ERROR" "Unable to find parent cell <$parentCell>!"}
     return
  }

  # Make sure parentObj is hier blk
  set parentType [get_property TYPE $parentObj]
  if { $parentType ne "hier" } {
     catch {common::send_msg_id "BD_TCL-101" "ERROR" "Parent <$parentObj> has TYPE = <$parentType>. Expected to be <hier>."}
     return
  }

  # Save current instance; Restore later
  set oldCurInst [current_bd_instance .]

  # Set parent object as current
  current_bd_instance $parentObj


  # Create interface ports

  # Create ports
  set Clock_250MHz [ create_bd_port -dir O -type clk Clock_250MHz ]
  set Fir_Output [ create_bd_port -dir O -from 31 -to 0 -type data Fir_Output ]
  set Mixed_Signals [ create_bd_port -dir O -from 8 -to 0 -type data Mixed_Signals ]
  set Sine_500KHz [ create_bd_port -dir O -from 7 -to 0 -type data Sine_500KHz ]
  set Sine_50MHz [ create_bd_port -dir O -from 7 -to 0 -type data Sine_50MHz ]

  # Create instance: c_addsub_0, and set properties
  set c_addsub_0 [ create_bd_cell -type ip -vlnv xilinx.com:ip:c_addsub:12.0 c_addsub_0 ]
  set_property -dict [ list \
   CONFIG.A_Type {Signed} \
   CONFIG.A_Width {8} \
   CONFIG.B_Constant {false} \
   CONFIG.B_Type {Signed} \
   CONFIG.B_Value {00000000} \
   CONFIG.B_Width {8} \
   CONFIG.CE {false} \
   CONFIG.Latency {2} \
   CONFIG.Latency_Configuration {Manual} \
   CONFIG.Out_Width {9} \
 ] $c_addsub_0

  # Create instance: dds_compiler_500KHz, and set properties
  set dds_compiler_500KHz [ create_bd_cell -type ip -vlnv xilinx.com:ip:dds_compiler:6.0 dds_compiler_500KHz ]
  set_property -dict [ list \
   CONFIG.DDS_Clock_Rate {250} \
   CONFIG.Frequency_Resolution {0.4} \
   CONFIG.Has_Phase_Out {false} \
   CONFIG.M_DATA_Has_TUSER {Not_Required} \
   CONFIG.Noise_Shaping {Auto} \
   CONFIG.Output_Frequency1 {0.5} \
   CONFIG.Output_Selection {Sine} \
   CONFIG.Output_Width {8} \
   CONFIG.PINC1 {1000001100010010011011} \
   CONFIG.Parameter_Entry {System_Parameters} \
   CONFIG.Phase_Width {30} \
 ] $dds_compiler_500KHz

  # Create instance: dds_compiler_50MHz, and set properties
  set dds_compiler_50MHz [ create_bd_cell -type ip -vlnv xilinx.com:ip:dds_compiler:6.0 dds_compiler_50MHz ]
  set_property -dict [ list \
   CONFIG.DATA_Has_TLAST {Not_Required} \
   CONFIG.DDS_Clock_Rate {250} \
   CONFIG.Frequency_Resolution {500000} \
   CONFIG.Has_Phase_Out {false} \
   CONFIG.Has_TREADY {false} \
   CONFIG.Latency {3} \
   CONFIG.M_DATA_Has_TUSER {Not_Required} \
   CONFIG.Mode_of_Operation {Standard} \
   CONFIG.Modulus {9} \
   CONFIG.Noise_Shaping {Auto} \
   CONFIG.Output_Frequency1 {50} \
   CONFIG.Output_Selection {Sine} \
   CONFIG.Output_Width {8} \
   CONFIG.PINC1 {1100110} \
   CONFIG.Parameter_Entry {System_Parameters} \
   CONFIG.PartsPresent {Phase_Generator_and_SIN_COS_LUT} \
   CONFIG.Phase_Width {9} \
   CONFIG.S_PHASE_Has_TUSER {Not_Required} \
 ] $dds_compiler_50MHz

  # Create instance: fir_compiler_0, and set properties
  set fir_compiler_0 [ create_bd_cell -type ip -vlnv xilinx.com:ip:fir_compiler:7.2 fir_compiler_0 ]
  set_property -dict [ list \
   CONFIG.Clock_Frequency {250.0} \
   CONFIG.CoefficientVector {2593.0, 3330.0, 5463.0, 8789.0, 12987.0, 17647.0, 22314.0, 26528.0, 29875.0, 32025.0, 32767.0, 32025.0, 29875.0, 26528.0, 22314.0, 17647.0, 12987.0, 8789.0, 5463.0, 3330.0, 2593.0} \
   CONFIG.Coefficient_Fractional_Bits {1} \
   CONFIG.Coefficient_Sets {1} \
   CONFIG.Coefficient_Sign {Unsigned} \
   CONFIG.Coefficient_Structure {Inferred} \
   CONFIG.Coefficient_Width {16} \
   CONFIG.ColumnConfig {11} \
   CONFIG.Data_Fractional_Bits {0} \
   CONFIG.Data_Sign {Signed} \
   CONFIG.Data_Width {9} \
   CONFIG.Filter_Architecture {Systolic_Multiply_Accumulate} \
   CONFIG.Output_Rounding_Mode {Full_Precision} \
   CONFIG.Output_Width {29} \
   CONFIG.Quantization {Quantize_Only} \
   CONFIG.Sample_Frequency {250} \
 ] $fir_compiler_0

  # Create instance: sim_clk_gen_0, and set properties
  set sim_clk_gen_0 [ create_bd_cell -type ip -vlnv xilinx.com:ip:sim_clk_gen:1.0 sim_clk_gen_0 ]
  set_property -dict [ list \
   CONFIG.FREQ_HZ {250000000} \
 ] $sim_clk_gen_0

  # Create instance: xlconstant_0, and set properties
  set xlconstant_0 [ create_bd_cell -type ip -vlnv xilinx.com:ip:xlconstant:1.1 xlconstant_0 ]

  # Create port connections
  connect_bd_net -net c_addsub_0_S [get_bd_ports Mixed_Signals] [get_bd_pins c_addsub_0/S] [get_bd_pins fir_compiler_0/s_axis_data_tdata]
  connect_bd_net -net dds_compiler_500KHz_m_axis_data_tdata [get_bd_ports Sine_500KHz] [get_bd_pins c_addsub_0/B] [get_bd_pins dds_compiler_500KHz/m_axis_data_tdata]
  connect_bd_net -net dds_compiler_50MHz_m_axis_data_tdata [get_bd_ports Sine_50MHz] [get_bd_pins c_addsub_0/A] [get_bd_pins dds_compiler_50MHz/m_axis_data_tdata]
  connect_bd_net -net fir_compiler_0_m_axis_data_tdata [get_bd_ports Fir_Output] [get_bd_pins fir_compiler_0/m_axis_data_tdata]
  connect_bd_net -net sim_clk_gen_0_clk [get_bd_ports Clock_250MHz] [get_bd_pins c_addsub_0/CLK] [get_bd_pins dds_compiler_500KHz/aclk] [get_bd_pins dds_compiler_50MHz/aclk] [get_bd_pins fir_compiler_0/aclk] [get_bd_pins sim_clk_gen_0/clk]
  connect_bd_net -net xlconstant_0_dout [get_bd_pins fir_compiler_0/s_axis_data_tvalid] [get_bd_pins xlconstant_0/dout]

  # Create address segments


  # Restore current instance
  current_bd_instance $oldCurInst

  validate_bd_design
  save_bd_design
  close_bd_design $design_name 
}
