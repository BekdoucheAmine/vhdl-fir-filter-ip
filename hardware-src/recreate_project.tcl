  set xlconstant_1 [ create_bd_cell -type ip -vlnv xilinx.com:ip:xlconstant:1.1 xlconstant_1 ]
  set_property -dict [ list \
   CONFIG.CONST_VAL {0} \
   CONFIG.CONST_WIDTH {15} \
 ] $xlconstant_1

  # Create port connections
  connect_bd_net -net c_counter_binary_0_THRESH0 [get_bd_pins c_counter_binary_0/THRESH0] [get_bd_pins xlconcat_0/In0]
  connect_bd_net -net fir_compiler_0_m_axis_data_tdata [get_bd_ports Fir_Output] [get_bd_pins fir_compiler_0/m_axis_data_tdata]
  connect_bd_net -net parallel_fir_filter_1_m_axis_tdata [get_bd_ports PFF_OUT] [get_bd_pins parallel_fir_filter_1/m_axis_tdata]
  connect_bd_net -net sim_clk_gen_0_clk [get_bd_ports Clock_250MHz] [get_bd_pins c_counter_binary_0/CLK] [get_bd_pins fir_compiler_0/aclk] [get_bd_pins parallel_fir_filter_1/clk] [get_bd_pins sim_clk_gen_0/clk]
  connect_bd_net -net sim_clk_gen_0_sync_rst [get_bd_pins parallel_fir_filter_1/rst_n] [get_bd_pins sim_clk_gen_0/sync_rst]
  connect_bd_net -net xlconcat_0_dout [get_bd_ports Impulse] [get_bd_pins fir_compiler_0/s_axis_data_tdata] [get_bd_pins parallel_fir_filter_1/s_axis_tdata] [get_bd_pins xlconcat_0/dout]
